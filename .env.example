# 数据模式: jnb(走Tushare API) 或 websearch(走网络搜索)
DATA_MODE=jnb

# Tushare API 配置
TUSHARE_TOKEN=你的56位token

# Tushare 中转 API 地址（可选，不填则使用 Tushare 官方地址）
# 格式: http://your-proxy-server.com
# TUSHARE_API_URL=
# TUSHARE_VERIFY_TOKEN_URL=

# 数据库配置
# 支持绝对路径或相对路径（相对于项目根目录）
DATA_DIR=data
DB_PATH=data/stock_data.db
